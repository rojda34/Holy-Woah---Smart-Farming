# ============================================================================
# KATS Project - Environment Variables Template
# Urban Rooftop Farming AI System
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in the actual values
#   3. NEVER commit .env (it's in .gitignore)
# ============================================================================

# STREAMLIT CONFIGURATION
STREAMLIT_THEME_BASE=light
STREAMLIT_THEME_PRIMARY_COLOR="#4A90E2"
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true

# DATABASE CONFIGURATION
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kats_production
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# API KEYS & SECRETS
OPENAI_API_KEY=your_openai_api_key_here
WEATHER_API_KEY=your_weather_api_key_here
GCP_PROJECT_ID=your_gcp_project_id

# MODEL CONFIGURATION
MODEL_WEIGHTS_PATH=models/weights/
SCALER_PATH=models/artifacts/scaler.pkl
VECTORIZER_PATH=models/artifacts/vectorizer.pkl
ANN_WEIGHT=0.35
SVM_WEIGHT=0.30
RF_WEIGHT=0.35

# RLHF & FEEDBACK
FEEDBACK_DB_TABLE=rlhf_feedback_history
LEARNING_RATE_ADJUSTMENT=0.02

# EMAIL NOTIFICATIONS
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
ADMIN_EMAIL=admin@kats-farm.com

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
SENTRY_DSN=https://your_sentry_dsn

# ENVIRONMENT
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your_secret_key_here_change_in_production

# FEATURE FLAGS
ENABLE_RLHF_FEEDBACK=true
ENABLE_DARK_MODE=false
ENABLE_EXPERIMENTAL_MODELS=false

# ROOFTOP FARM LOCATION
FARM_LATITUDE=41.3851
FARM_LONGITUDE=2.1734
FARM_TIMEZONE=Europe/Madrid
FARM_NAME=Barcelona Urban Rooftop Farm

# SENSOR DATA
SENSOR_REFRESH_INTERVAL=300  # seconds
SENSOR_DATA_RETENTION_DAYS=90
BATCH_SIZE=32

# AI MODEL SETTINGS
MODEL_BATCH_SIZE=32
TRAINING_EPOCHS=100
VALIDATION_SPLIT=0.2
TEST_SPLIT=0.1
RANDOM_SEED=42

# NOTIFICATIONS
ENABLE_ALERTS=true
CRITICAL_ALERT_THRESHOLD=80
WARNING_ALERT_THRESHOLD=60
